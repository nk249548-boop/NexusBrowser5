<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        PUBLIC Downloads/NexusBrowser — primary download destination.
        DownloadHelper saves files here via DownloadManager.
    -->
    <external-path
        name="public_nexus_downloads"
        path="Download/NexusBrowser/" />

    <!-- All public external storage (for opening any file from public Downloads) -->
    <external-path
        name="public_downloads_root"
        path="Download/" />

    <!-- App-private external storage (DownloadService saves here) -->
    <external-files-path
        name="app_downloads"
        path="Downloads/" />

    <external-files-path
        name="app_downloads_lower"
        path="downloads/" />

    <!-- External files root (catch-all) -->
    <external-files-path
        name="app_external_root"
        path="." />

    <!-- Internal cache (screenshots, temp files) -->
    <cache-path
        name="cache_root"
        path="." />

    <!-- Files dir -->
    <files-path
        name="files_root"
        path="." />
</paths>
